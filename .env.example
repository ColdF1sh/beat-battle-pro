DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"

STORAGE_PROVIDER="r2"

R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="replace-me"
R2_SECRET_ACCESS_KEY="replace-me"
R2_BUCKET_NAME="beat-battle-pro-audio"
R2_PUBLIC_URL="https://<public-r2-domain>.r2.dev"
R2_REGION="auto"

# Test/dev deployment controls. Keep both false in real production.
ENABLE_DEV_FAKE_PLAYERS="true"
ENABLE_BATTLE_DEV_TOOLS="true"
ENABLE_LOCAL_DEMO_AUDIO="false"

# Optional local MinIO S3-compatible storage for development.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="replace-me"
S3_SECRET_ACCESS_KEY="replace-me"
S3_BUCKET_NAME="beat-battle-audio"
S3_PUBLIC_URL="http://localhost:9000/beat-battle-audio"
S3_FORCE_PATH_STYLE="true"
